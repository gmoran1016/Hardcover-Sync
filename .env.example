# ---------------------------------------------------------------
# Copy this file to .env and fill in your credentials.
# Never commit .env to git.
# ---------------------------------------------------------------

# Hardcover API key (required)
# Get yours at: https://hardcover.app/settings → API key
HARDCOVER_API_KEY=your_hardcover_api_key_here

# Goodreads credentials (optional when cookies/goodreads.json exists)
# Used only as a fallback if cookie authentication is unavailable.
GOODREADS_EMAIL=
GOODREADS_PASSWORD=

# StoryGraph credentials (optional — leave blank to skip StoryGraph sync)
STORYGRAPH_EMAIL=
STORYGRAPH_PASSWORD=

# How often to sync, in minutes (default: 30)
SYNC_INTERVAL_MINUTES=30
