# ---------------------------------------------------------------
# Copy this file to .env and fill in your credentials.
# Never commit .env to git.
# ---------------------------------------------------------------

# Hardcover API key (required)
# Get yours at: https://hardcover.app/settings → API key
HARDCOVER_API_KEY=your_hardcover_api_key_here

# Goodreads credentials (required)
# The email and password you use to log in to goodreads.com
GOODREADS_EMAIL=you@example.com
GOODREADS_PASSWORD=your_goodreads_password

# StoryGraph credentials (optional — leave blank to skip StoryGraph sync)
STORYGRAPH_EMAIL=
STORYGRAPH_PASSWORD=

# How often to sync, in minutes (default: 30)
SYNC_INTERVAL_MINUTES=30
